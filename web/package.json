{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "bootstrap": "^5.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "^5.0.1",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-fr": "^3.0.2"
  },
  "scripts": {
    "start:js": "react-scripts start",
    "build:js": "react-scripts build",
    "start": "react-scripts start",
    "build": "npm-run-all build:css build:js",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "build:css": "sass --include-path ./src --include-path ./node_modules src/ -o src/",
    "watch:css": "npm run build:css && sass --include-path ./src --include-path ./node_modules src/ -o src/ --watch --recursive",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "sass": "^1.49.9",
    "npm-run-all": "^4.1.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^4.9.5",
    "@types/node": "^20.14.0",
    "@types/jest": "^29.5.0",
    "prettier": "^3.3.0"
  },
  "keywords": [],
  "description": "",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
